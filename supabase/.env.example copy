# BOV Finance App — Supabase credentials
# Copy this file to: supabase/.env
# Fill in your actual values from the Supabase dashboard.
# Never commit .env to version control.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Use only for local scripts.
# Do NOT expose it in the web app — use the anon key there instead.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_KEY_HERE
